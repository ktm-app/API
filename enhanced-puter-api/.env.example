# Enhanced Puter API Wrapper - Environment Configuration Example
# Copy this file to .env and update the values for your deployment

# ================================
# REQUIRED CONFIGURATION
# ================================

# Puter Credentials (REQUIRED)
# Get these from your Puter account at https://puter.com
PUTER_USERNAME=your_puter_username_here
PUTER_PASSWORD=your_puter_password_here

# ================================
# FLASK CONFIGURATION
# ================================

# Environment mode (development, production, testing)
FLASK_ENV=production

# Flask secret key (generate a random string for production)
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_secret_key_in_production

# ================================
# SERVER CONFIGURATION
# ================================

# Server host and port
HOST=0.0.0.0
PORT=5000

# ================================
# API CONFIGURATION
# ================================

# CORS origins (comma-separated list of allowed origins, * for all)
CORS_ORIGINS=*

# Puter API test mode (true/false)
# Set to true for development/testing, false for production
PUTER_TEST_MODE=false

# API timeout in seconds
PUTER_TIMEOUT=30

# ================================
# LOGGING CONFIGURATION
# ================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log to stdout (true/false) - recommended for cloud deployments
LOG_TO_STDOUT=true

# ================================
# RATE LIMITING (OPTIONAL)
# ================================

# Enable rate limiting (true/false) - requires Redis
RATELIMIT_ENABLED=false

# Redis URL for rate limiting (optional)
# Format: redis://username:password@hostname:port/database
# Example: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# Default rate limit (requests per time period)
RATELIMIT_DEFAULT=1000 per hour

# ================================
# FILE UPLOAD CONFIGURATION
# ================================

# Maximum file upload size in bytes (100MB default)
MAX_CONTENT_LENGTH=104857600

# ================================
# DEPLOYMENT SPECIFIC
# ================================

# Database URL (if using a database in future versions)
# DATABASE_URL=sqlite:///puter_api.db

# Additional security headers (production)
# SECURE_HEADERS=true

# ================================
# EXAMPLE VALUES FOR DEVELOPMENT
# ================================

# For local development, you might use:
# FLASK_ENV=development
# LOG_LEVEL=DEBUG
# PUTER_TEST_MODE=true
# HOST=127.0.0.1
# PORT=5000

# ================================
# DEPLOYMENT PLATFORM SPECIFIC
# ================================

# Render.com deployment
# Set these in the Render dashboard environment variables section:
# - PUTER_USERNAME
# - PUTER_PASSWORD
# - SECRET_KEY
# Other variables can be set in render.yaml or dashboard

# Heroku deployment  
# Set these using: heroku config:set VARIABLE_NAME=value
# - PUTER_USERNAME
# - PUTER_PASSWORD  
# - SECRET_KEY

# Docker deployment
# Create a .env file with these variables or pass them as environment variables
# docker run -d --env-file .env your-image-name

# ================================
# SECURITY NOTES
# ================================

# NEVER commit the actual .env file to version control
# ALWAYS use strong, unique passwords for Puter credentials
# GENERATE a random SECRET_KEY for production deployments
# CONSIDER using environment-specific configurations
# ROTATE credentials periodically
# USE HTTPS in production environments
# MONITOR API usage and set appropriate rate limits

# ================================
# GETTING STARTED
# ================================

# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Update PUTER_USERNAME and PUTER_PASSWORD with your actual credentials
#
# 3. Generate and set a secure SECRET_KEY:
#    python -c "import secrets; print(secrets.token_hex(32))"
#
# 4. Adjust other settings as needed for your environment
#
# 5. Start the application:
#    python run.py
#
# 6. Test the API:
#    curl http://localhost:5000/api/health

# For help and documentation, visit:
# - Puter Documentation: https://docs.puter.com
# - GitHub Repository: [Your repository URL]
# - API Documentation: http://localhost:5000/ (when running)
