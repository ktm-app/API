# Enhanced Puter API Wrapper - Quick Setup
# Rename this file to .env and update the values

# REQUIRED: Your Puter credentials
PUTER_USERNAME=your_puter_username_here
PUTER_PASSWORD=your_puter_password_here

# REQUIRED: Generate a secret key
SECRET_KEY=change_this_to_a_random_secret_key

# Optional configuration
FLASK_ENV=production
LOG_LEVEL=INFO
PUTER_TEST_MODE=false
PORT=5000
HOST=0.0.0.0
CORS_ORIGINS=*
